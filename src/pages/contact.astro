---
import Layout from '../layouts/Layout.astro';

const links = [
	{ label: 'Email', value: 'john.smith@example.com', href: 'mailto:john.smith@example.com' },
	{ label: 'GitHub', value: 'github.com/example', href: 'https://github.com/example' },
	{ label: 'LinkedIn', value: 'linkedin.com/in/example', href: 'https://linkedin.com/in/example' },
];
---

<Layout title="Contact" description="Get in touch with John Smith.">
	<h1>Contact</h1>
	<p class="muted">
		The fastest way to reach me is email. I'm happy to talk about distributed
		systems, developer tooling, or interesting problems in general.
	</p>
	<ul class="links">
		{
			links.map((link) => (
				<li>
					<span class="label muted">{link.label}</span>
					<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer noopener">
						{link.value}
					</a>
				</li>
			))
		}
	</ul>
</Layout>

<style>
	h1 {
		margin-bottom: 1rem;
	}

	.links {
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.links li {
		display: flex;
		align-items: baseline;
		gap: 1rem;
	}

	.label {
		width: 5rem;
		flex-shrink: 0;
		font-size: 0.875rem;
	}
</style>

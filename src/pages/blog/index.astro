---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatter = new Intl.DateTimeFormat('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});
---

<Layout title="Blog" description="Writing on software, systems, and engineering.">
	<h1>Blog</h1>
	<ul class="posts">
		{
			posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`}>
						<h2>{post.data.title}</h2>
					</a>
					<p class="muted date">{formatter.format(post.data.date)}</p>
					<p class="muted">{post.data.description}</p>
				</li>
			))
		}
	</ul>
</Layout>

<style>
	h1 {
		margin-bottom: 2rem;
	}

	.posts {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.posts a {
		text-decoration: none;
	}

	.posts h2 {
		font-size: 1.15rem;
		margin: 0 0 0.25rem;
		color: var(--text);
	}

	.date {
		font-size: 0.875rem;
		margin: 0 0 0.5rem;
	}
</style>

---
import Layout from '../layouts/Layout.astro';

const experience = [
	{
		role: 'Senior Application Engineer',
		company: 'Synopsys',
		period: 'January 2023 — November 2025',
		description:
			'Resolved design issues through rigorous C code debugging and Verilog simulation to reproduce and fix customer-reported IP defects in Cryptography and Processor product lines. Accelerated ASIC development cycles by leading customer communications and synchronizing implementation roadmaps with internal R&D departments.Secured high-value support contracts (valued at hundreds of thousands of dollars) by providing expert-level technical support for Cryptography IPs and ARC processors.',
	},
	{
		role: 'Hardware Engineer',
		company: 'MS4M',
		period: 'June 2019 — December 2022',
		description:
			'Engineered end-to-end computer vision solutions for the mining industry, taking projects from academic research to full-scale physical deployment. Development of Object Detection solution using Python with PyTorch to train YOLO model and deployed onto embedded systems using C++ for high-efficiency inference. Managed on-site installations of ruggedized hardware, ensuring compliance with strict industrial security and networking standards.',
	},
	{
		role: 'Support Engineer',
		company: 'GRUPO RPP',
		period: 'April 2018 — December 2018',
		description:
			'Provided comprehensive technical support for television production and transmission equipment, including server configuration, networking maintenance, and the setup of audio and video systems for broadcasting.',
	},
];

const education = {
	degree: 'B.S. in Electronic Engineering',
	school: 'Pontifical Catholic University of Peru',
	period: '2013 — 2017',
};
---

<Layout title="Home">
	<section class="intro">
		<h1>Marco Portocarrero</h1>
		<p class="muted">
			marcoa.portocarrero@gmail.com
		</p>
		<p>
			Electronic Engineer with experience developing integrated software and hardware solutions for the semiconductor,
			mining, and telecommunica6ons sectors. Expert in C/C++, Embedded Systems, asnd Computer Vision, with a proven track record
			of managing complex ASIC/IP integrations and deploying physical solutions in high-stakes environments.
		</p>
	</section>

	<section>
		<h2>Experience</h2>
		<ul class="timeline">
			{
				experience.map((job) => (
					<li>
						<div class="timeline-header">
							<h3>{job.role} · {job.company}</h3>
							<span class="muted">{job.period}</span>
						</div>
						<p class="muted">{job.description}</p>
					</li>
				))
			}
		</ul>
	</section>

	<section>
		<h2>Education</h2>
		<div class="timeline-header">
			<h3>{education.degree}</h3>
			<span class="muted">{education.period}</span>
		</div>
		<p class="muted">{education.school}</p>
	</section>
</Layout>

<style>
	.intro {
		margin-bottom: 3rem;
	}

	.intro h1 {
		font-size: clamp(1.75rem, 1.5rem + 1.5vw, 2.5rem);
		margin-bottom: 0.25rem;
	}

	section {
		margin-bottom: 2.5rem;
	}

	section h2 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.timeline-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.timeline-header h3 {
		font-size: 1rem;
		margin: 0;
	}

	.timeline-header span {
		font-size: 0.875rem;
		white-space: nowrap;
	}
</style>
